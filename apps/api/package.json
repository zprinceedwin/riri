{
  "name": "@riri/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "start": "tsx --env-file=../../.env src/index.ts",
    "start:prod": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "seed:company": "tsx --env-file=../../.env src/seed/seed-company.ts",
    "seed:prospect": "tsx --env-file=../../.env src/seed/seed-prospect.ts",
    "seed:clinic": "tsx --env-file=../../.env src/seed/seed-clinic.ts",
    "seed:clinic": "tsx --env-file=../../.env src/seed/seed-clinic.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.2",
    "@riri/personas": "workspace:*",
    "@riri/shared": "workspace:*",
    "@supabase/supabase-js": "^2.45.4",
    "agora-token": "^2.0.5",
    "cheerio": "^1.0.0",
    "hono": "^4.6.5",
    "nanoid": "^5.0.7",
    "openai": "^4.67.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
