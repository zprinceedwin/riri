# =============================================================================
# Riri - Voice AI Sales Agents
# Copy this file to .env and fill in the values.
# Both apps/api and apps/web read from this single root .env via dotenv.
# =============================================================================

# -----------------------------------------------------------------------------
# AGORA (required) - https://console.agora.io
# -----------------------------------------------------------------------------
# From Agora Console > Project Management
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# From Agora Console > Developer Toolkit > RESTful API
# These are base64-encoded as "Basic <base64(customer_id:customer_secret)>"
AGORA_CUSTOMER_ID=your_agora_customer_id_here
AGORA_CUSTOMER_SECRET=your_agora_customer_secret_here

# -----------------------------------------------------------------------------
# OPENAI (required) - https://platform.openai.com
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# ELEVENLABS (required for TTS) - https://elevenlabs.io
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_key_here
# Voice IDs - get these from ElevenLabs Voice Library
# Jordan: fast-paced, charismatic, male - try "Brian" (nPczCjzI2devNBz1zQrb) or "Adam"
ELEVENLABS_VOICE_ID_JORDAN=nPczCjzI2devNBz1zQrb
# Mike: calm, authoritative, male - try "Daniel" (onwK4e9ZLuTAKqWW03F9) or "George"
ELEVENLABS_VOICE_ID_MIKE=onwK4e9ZLuTAKqWW03F9

# -----------------------------------------------------------------------------
# DEEPGRAM (required for ASR) - https://console.deepgram.com
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_key_here

# -----------------------------------------------------------------------------
# COUCHBASE CAPELLA (required) - https://cloud.couchbase.com
# -----------------------------------------------------------------------------
# Connection string from Capella > Cluster > Connect (format: couchbases://cb.xxx.cloud.couchbase.com)
COUCHBASE_CONNECTION_STRING=couchbases://your_cluster.cloud.couchbase.com
COUCHBASE_USERNAME=your_db_username
COUCHBASE_PASSWORD=your_db_password
COUCHBASE_BUCKET=Riri
COUCHBASE_SCOPE=_default
# Collections (we create knowledge for vector RAG, calls for post-call records)
COUCHBASE_COLLECTION_KNOWLEDGE=knowledge
COUCHBASE_COLLECTION_CALLS=calls
# Vector search index name (created via Capella UI - see infra/couchbase-vector-index.md)
COUCHBASE_VECTOR_INDEX=riri_vector_idx

# -----------------------------------------------------------------------------
# Riri APP (the LLM proxy URL Agora will call)
# -----------------------------------------------------------------------------
# Local dev: http://localhost:3001 (but Agora needs a PUBLIC url - use ngrok/cloudflared)
# Prod: https://your-railway-app.up.railway.app
API_BASE_URL=http://localhost:3001
# This is the URL Agora's Conversational AI engine will POST to as its llm.url
LLM_PROXY_URL=http://localhost:3001/v1/chat/completions

# Public URL of the web app (for CORS)
WEB_BASE_URL=http://localhost:3000

# API listen port
PORT=3001

# Next.js public-facing API URL (used by browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
